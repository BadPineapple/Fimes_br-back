-- 1. Tabelas sem Chaves Estrangeiras (Base)
CREATE TABLE TBLROL (
    id INT PRIMARY KEY AUTO_INCREMENT,
    nome_role VARCHAR(50) NOT NULL
);

CREATE TABLE TBLGEN (
    id INT PRIMARY KEY AUTO_INCREMENT,
    genero VARCHAR(50) NOT NULL
);

CREATE TABLE TBLPES (
    id INT PRIMARY KEY AUTO_INCREMENT,
    pessoa VARCHAR(100) NOT NULL
);

CREATE TABLE TBLTAG (
    id INT PRIMARY KEY AUTO_INCREMENT,
    tag VARCHAR(50) NOT NULL
);

CREATE TABLE TLBPLA (
    id INT PRIMARY KEY AUTO_INCREMENT,
    plataforma VARCHAR(100) NOT NULL,
    link VARCHAR(255)
);

-- 2. Tabela de Login (Usuários)

CREATE TABLE TBLLOGIN (
    id INT PRIMARY KEY AUTO_INCREMENT,
    usuario VARCHAR(50) UNIQUE NOT NULL,
    email VARCHAR(100) UNIQUE NOT NULL,
    senha VARCHAR(255) NULL,
    auth_provider VARCHAR(50) DEFAULT 'local', -- Para identificar se é 'local' ou 'google'
    provider_id VARCHAR(255),                  -- ID retornado pelo Google
    email_verificado BOOLEAN DEFAULT FALSE,
    token_verificacao VARCHAR(255)
    telefone VARCHAR(20),
    data DATE,
    ultimo_acesso DATETIME
);

CREATE TABLE TBLUSER (
    id INT PRIMARY KEY AUTO_INCREMENT,
    login_id INT UNIQUE NOT NULL,
    foto_perfil VARCHAR(255),
    nome VARCHAR(100) NOT NULL,
    descricao TEXT,
    data_nascimento DATE,
    apoiador BOOLEAN DEFAULT FALSE,
    propaganda BOOLEAN DEFAULT FALSE,
    FOREIGN KEY (login_id) REFERENCES login(id) ON DELETE CASCADE
);

-- 3. Tabela de Filmes
-- Nota: Para campos como 'elenco', o ideal seria uma tabela N:N, 
-- mas seguindo seu diagrama, eles estão como FKs diretas.
CREATE TABLE TBLFIL (
    id INT PRIMARY KEY AUTO_INCREMENT,
    titulo VARCHAR(150) NOT NULL,
    sinopse TEXT,
    tmdb_id INT UNIQUE,
    nota_externa DECIMAL(3,1)
    imagens VARCHAR(255),
    duracao VARCHAR(20),
    ano INT,
);

-- 4. Tabelas de Relacionamento e Dependência


CREATE TABLE TBLLOG_ROL (
    id INT PRIMARY KEY AUTO_INCREMENT,
    role INT,
    usuario INT,
    FOREIGN KEY (role) REFERENCES Roles(id) ON DELETE RESTRICT ,
    FOREIGN KEY (login) REFERENCES Login(id) ON DELETE CASCADE 
);

CREATE TABLE TBLREV (
    id INT PRIMARY KEY AUTO_INCREMENT,
    usuario INT,
    nota INT CHECK (nota >= 0 AND nota <= 10),
    comentario TEXT,
    data DATE,
    filme INT,
    status VARCHAR(20),
    FOREIGN KEY (usuario) REFERENCES Login(id) ON DELETE CASCADE,
    FOREIGN KEY (filme) REFERENCES Filmes(id) ON DELETE CASCADE
);

CREATE TABLE TBLFIL_PES (
    filme_id INT,
    pessoa_id INT,
    funcao VARCHAR(50), -- Exemplos: 'Elenco', 'Diretor', 'Roteirista'
    FOREIGN KEY (filme_id) REFERENCES TBLFIL(id) ON DELETE CASCADE,
    FOREIGN KEY (pessoa_id) REFERENCES TBLPES(id) ON DELETE CASCADE,
    PRIMARY KEY (filme_id, pessoa_id, funcao)
);

-- Relaciona um filme a vários gêneros
CREATE TABLE TBLFIL_GEN (
    filme_id INT,
    genero_id INT,
    FOREIGN KEY (filme_id) REFERENCES TBLFIL(id) ON DELETE CASCADE,
    FOREIGN KEY (genero_id) REFERENCES TBLGEN(id) ON DELETE CASCADE,
    PRIMARY KEY (filme_id, genero_id)
);

-- Relaciona um filme a várias tags
CREATE TABLE TBLFIL_TAG (
    filme_id INT,
    tag_id INT,
    FOREIGN KEY (filme_id) REFERENCES TBLFIL(id) ON DELETE CASCADE,
    FOREIGN KEY (tag_id) REFERENCES TBLTAG(id) ON DELETE CASCADE,
    PRIMARY KEY (filme_id, tag_id)
);

-- Relaciona um filme a várias plataformas
CREATE TABLE TBLFIL_PLA (
    filme_id INT,
    plataforma_id INT,
    FOREIGN KEY (filme_id) REFERENCES TBLFIL(id) ON DELETE CASCADE,
    FOREIGN KEY (plataforma_id) REFERENCES TLBPLA(id) ON DELETE CASCADE,
    PRIMARY KEY (filme_id, plataforma_id)
);