const multer = require('multer');

// 1. Configurar o armazenamento em Memória (RAM)
// Precisamos disso porque o nosso imagemController usa o "req.file.buffer" 
// para passar a imagem diretamente para o Sharp antes de salvar no HD.
const storage = multer.memoryStorage();

// 2. Criar o middleware com as regras de segurança
const upload = multer({
    storage: storage,
    limits: {
        fileSize: 5 * 1024 * 1024, // Limite de 5MB por imagem (evita sobrecarregar o servidor)
    },
    fileFilter: (req, file, cb) => {
        // 3. Filtro de Segurança: Aceitar apenas ficheiros do tipo imagem
        // O mimetype de imagens começa sempre com "image/" (ex: image/jpeg, image/png, image/webp)
        if (file.mimetype.startsWith('image/')) {
            cb(null, true); // Permite o upload
        } else {
            // Rejeita o upload e envia um erro
            cb(new Error('Formato de arquivo inválido. Apenas imagens são permitidas!'), false);
        }
    }
});

module.exports = upload;