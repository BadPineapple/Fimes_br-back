generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Genre {
  id        String      @id @default(cuid())
  name      String
  slug      String      @unique
  films     FilmGenre[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model Tag {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  films     FilmTag[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Person {
  id        String       @id @default(cuid())
  name      String
  slug      String       @unique
  photoUrl  String?
  bio       String?
  bornAt    DateTime?
  diedAt    DateTime?
  credits   FilmPerson[] // atuações e direções
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

model StreamingPlatform {
  id        String               @id @default(cuid())
  name      String
  slug      String               @unique
  logoUrl   String?
  website   String?
  films     FilmAvailability[]
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
}

model Film {
  id            String              @id @default(cuid())
  title         String
  originalTitle String?
  slug          String?
  year          Int?
  runtimeMin    Int?
  synopsis      String?
  coverUrl      String?

  // relações
  ratings       Rating[]
  genres        FilmGenre[]
  tags          FilmTag[]
  people        FilmPerson[]        // Atores e Diretores (role no pivot)
  whereToWatch  FilmAvailability[]

  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
}

// ----- Tabelas intermediárias (N:N)
model FilmGenre {
  filmId  String
  genreId String
  film    Film   @relation(fields: [filmId],  references: [id], onDelete: Cascade)
  genre   Genre  @relation(fields: [genreId], references: [id], onDelete: Cascade)

  @@id([filmId, genreId])
  @@index([genreId])
}

model FilmTag {
  filmId String
  tagId  String
  film   Film @relation(fields: [filmId], references: [id], onDelete: Cascade)
  tag    Tag  @relation(fields: [tagId],  references: [id], onDelete: Cascade)

  @@id([filmId, tagId])
  @@index([tagId])
}

model FilmPerson {
  filmId        String
  personId      String
  role          String  @default("ACTOR")
  characterName String?
  billingOrder  Int?       // 1,2,3… para ordenar elenco

  film   Film   @relation(fields: [filmId],   references: [id], onDelete: Cascade)
  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@id([filmId, personId, role])
  @@index([personId, role])
  @@index([filmId, role, billingOrder])
}

// Disponibilidades de streaming por filme
model FilmAvailability {
  filmId     String
  platformId String
  type       String
  url        String?
  region     String?
  lastCheck  DateTime?

  film      Film              @relation(fields: [filmId],     references: [id], onDelete: Cascade)
  platform  StreamingPlatform @relation(fields: [platformId], references: [id], onDelete: Cascade)

  @@id([filmId, platformId, type])
  @@index([platformId])
}


model User {
  id           String  @id @default(cuid())
  name         String?
  email        String  @unique
  role         String  @default("user") // 'user' | 'moderator' | 'admin'
  isSupporter  Boolean @default(false)
  isPrivate    Boolean @default(false)
  description  String? 
  avatarUrl    String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  ratings      Rating[]
}

model Rating {
  id        String   @id @default(cuid())
  userId    String
  filmId    String
  score     Int      // 1..5, por exemplo
  comment   String?
  createdAt DateTime @default(now())

  user  User @relation(fields: [userId], references: [id])
  film  Film @relation(fields: [filmId], references: [id])

  @@unique([userId, filmId]) // 1 avaliação por usuário/filme
}
